generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssessmentType {
  GSES
  CUAS
  AI_USAGE
  FULL_BATTERY
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  name          String
  createdAt     DateTime       @default(now()) @map("created_at")
  assessments   Assessment[]
  trendReports  TrendReport[]

  @@map("users")
}

model TrendReport {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  report    String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@map("trend_reports")
}

model Assessment {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      AssessmentType
  responses Json
  scores    Json
  createdAt DateTime       @default(now()) @map("created_at")

  @@map("assessments")
}
